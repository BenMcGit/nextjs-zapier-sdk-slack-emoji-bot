# Zapier SDK OAuth credentials
# Run: npx zapier-sdk login && npx zapier-sdk create-client-credentials "my-bot-name"
ZAPIER_CREDENTIALS_CLIENT_ID=
ZAPIER_CREDENTIALS_CLIENT_SECRET=

# Public base URL for Zapier notification callbacks.
# On Vercel this is auto-set from VERCEL_PROJECT_PRODUCTION_URL — no action needed.
# Required only for local dev (e.g. an ngrok tunnel URL).
APP_BASE_URL=

# Shared secret appended to webhook URLs as ?token=... (optional but recommended)
# Run: pnpm generate:secret
ZAPIER_WEBHOOK_SECRET=

# --- Bot configuration ---
# Slack channel ID to watch (right-click channel name in Slack → Copy link → the ID is the last segment)
SLACK_CHANNEL_ID=
# Emoji name without colons, e.g. "dwight"
SLACK_EMOJI=
# Message the bot posts in the thread
BOT_MESSAGE=
